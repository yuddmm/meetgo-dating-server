# Application
ENV=dev
HTTP_PORT=8080
LOG_LEVEL=info

# Auth (dev defaults applied when unset; JWT_SECRET is REQUIRED in prod)
JWT_SECRET=dev-insecure-secret-change-me
ACCESS_TTL=15m
REFRESH_TTL=1440h
OTP_TTL=5m
OTP_RESEND_AFTER=60s

# Database (used by the app at runtime)
DATABASE_URL=postgres://postgres:12345@localhost:5432/meetgo?sslmode=disable

# Photo storage: local (dev, filesystem) | s3 (prod, S3-compatible)
STORAGE_PROVIDER=local
STORAGE_PUBLIC_URL=http://localhost:8080/uploads
STORAGE_LOCAL_DIR=./uploads
# For STORAGE_PROVIDER=s3 (MinIO/AWS S3/Cloudflare R2):
# STORAGE_S3_ENDPOINT=localhost:9000
# STORAGE_S3_BUCKET=meetgo
# STORAGE_S3_ACCESS_KEY=...
# STORAGE_S3_SECRET_KEY=...
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_USE_SSL=false

# GeoIP: path to a MaxMind/DB-IP country .mmdb. Empty = geo disabled (no RU-email rule).
# When set and the client IP resolves to RU, a Russian email (.ru/.su/.рф) is required.
# In ENV=dev the X-Debug-Country header overrides GeoIP for testing.
# GEOIP_DB_PATH=./GeoLite2-Country.mmdb

# Postgres container settings (used by docker-compose)
POSTGRES_USER=meetgo
POSTGRES_PASSWORD=meetgo
POSTGRES_DB=meetgo
POSTGRES_PORT=5432
