                },
                "interestIds": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "showZodiac": {
                    "type": "boolean"
                },
                "weight": {
                    "description": "kg, optional",
                    "type": "number"
                }
            }
        },
        "profile.basicsRequest": {
            "type": "object",
            "properties": {
                "birthDate": {
                    "description": "YYYY-MM-DD",
                    "type": "string"
                },
                "city": {
                    "type": "string"
                },
                "gender": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "profile.completeResponse": {
            "type": "object",
            "properties": {
                "isCreatedProfile": {
                    "type": "boolean"
                },
                "onboardingStep": {
                    "type": "string"
                }
