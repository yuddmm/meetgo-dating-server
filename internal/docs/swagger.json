    "definitions": {
        "auth.checkCodeRequest": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                }
            }
        },
        "auth.meResponse": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "isCreatedProfile": {
                    "type": "boolean"
                },
                "onboardingStep": {
                    "type": "string"
                }
            }
        },
        "auth.refreshRequest": {
            "type": "object",
            "properties": {
                "refreshToken": {
                    "type": "string"
                }
            }
        },
        "auth.sendCodeRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                }
            }
        },
        "auth.sendCodeResponse": {
            "type": "object",
            "properties": {
                "expiresIn": {
                    "description": "seconds",
                    "type": "integer"
                },
                "resendAfter": {
                    "description": "seconds",
                    "type": "integer"
                }
            }
        },
        "auth.tokenResponse": {
            "type": "object",
            "properties": {
                "accessToken": {
                    "type": "string"
                },
                "isCreatedProfile": {
                    "type": "boolean"
                },
                "onboardingStep": {
                    "type": "string"
                },
                "refreshToken": {
                    "type": "string"
                }
            }
        },
        "interest.Interest": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "value": {
                    "type": "string"
                }
            }
        },
        "profile.aboutRequest": {
            "type": "object",
            "properties": {
                "datingGoal": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "height": {
                    "description": "cm, optional",
